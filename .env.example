# Intelli-Credit Configuration
# Copy this file to .env and fill in your API keys

# App Mode: "demo" (mock data, no APIs needed) or "live" (real APIs)
APP_MODE=demo

# ═══════════════════════════════════════════════
# LLM Provider: "openai" or "anthropic"
# ═══════════════════════════════════════════════
LLM_PROVIDER=openai

# OpenAI API Key (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic/Claude API Key (if LLM_PROVIDER=anthropic)
# As recommended in architecture: claude-sonnet-4-6
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override default model
# LLM_MODEL=gpt-4o
# LLM_MODEL=claude-sonnet-4-20250514

# ═══════════════════════════════════════════════
# Tavily API Key (for web search agents)
# Free tier: https://tavily.com
# ═══════════════════════════════════════════════
TAVILY_API_KEY=your_tavily_api_key_here

# ═══════════════════════════════════════════════
# Azure Document Intelligence (Primary OCR Engine)
# https://azure.microsoft.com/en-us/products/ai-services/ai-document-intelligence
# ═══════════════════════════════════════════════
AZURE_DI_ENDPOINT=your_azure_di_endpoint_here
AZURE_DI_KEY=your_azure_di_key_here

# ═══════════════════════════════════════════════
# Databricks (Delta Lake Data Platform)
# As specified in the problem statement
# ═══════════════════════════════════════════════
DATABRICKS_HOST=your_databricks_host_here
DATABRICKS_TOKEN=your_databricks_token_here
DATABRICKS_WAREHOUSE_ID=your_warehouse_id_here
DATABRICKS_CATALOG=intelli_credit
DATABRICKS_SCHEMA=credit_engine

# ═══════════════════════════════════════════════
# Optional: Tesseract OCR path (fallback for scanned PDFs)
# Windows default: C:\Program Files\Tesseract-OCR\tesseract.exe
# ═══════════════════════════════════════════════
TESSERACT_PATH=

# ════════════════════════════════════════════════════════════════════════════
# Optional: Object Storage (S3 / Cloudflare R2) for large file uploads on Vercel
# Configure these to enable direct-to-storage uploads (bypasses Vercel 4.5MB limit).
# ════════════════════════════════════════════════════════════════════════════
S3_BUCKET=
# For AWS S3 you can leave this empty. For R2 use: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
S3_REGION=auto
S3_PREFIX=uploads
S3_ADDRESSING_STYLE=auto
S3_UPLOAD_MAX_MB=50
S3_DELETE_AFTER_PROCESS=false

# Standard AWS credentials (works for S3 and S3-compatible providers like R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
